---
export const prerender = true;

import SiteLayout from '../layouts/SiteLayout.astro';
import ClinicsDirectoryPage from '../components/ClinicsDirectoryPage';

const title = 'EU-Kliniken durchsuchen | Roser';
const description =
  'Durchsuchen Sie Kinderwunschkliniken in Europa nach Name, Stadt und Land — IVF, ICSI und weitere Behandlungen.';
---

<SiteLayout title={title} description={description} canonicalPath="/kliniken">
  <ClinicsDirectoryPage client:load />
</SiteLayout>
