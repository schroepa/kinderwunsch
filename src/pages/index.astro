---
export const prerender = true;

import '../styles/globals.css';
import FertilityApp from '../components/FertilityApp';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Finden Sie die beste Kinderwunschklinik in Europa für Ihre individuelle Situation" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Kinderwunsch-Finder | IVF & ICSI Kliniken in Europa</title>
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('kinderwunsch-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored === 'dark' || stored === 'light' ? stored : prefersDark ? 'dark' : 'light';
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <FertilityApp client:load />
  </body>
</html>
