---
export const prerender = true;

import SiteLayout from '../layouts/SiteLayout.astro';
import FertilityApp from '../components/FertilityApp';
import { SITE_ORIGIN } from '../lib/wissen';

const title = 'Roser | IVF & ICSI Kliniken in Europa';
const description =
  'Roser hilft Paaren und Alleinstehenden, passende IVF- und ICSI-Länder sowie Kliniken in Europa zu finden — nach Alter, Beziehungsstatus, Budget und Behandlung.';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Roser',
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Web',
  inLanguage: 'de',
  description,
  url: SITE_ORIGIN,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
  },
  about: [
    { '@type': 'Thing', name: 'IVF' },
    { '@type': 'Thing', name: 'ICSI' },
    { '@type': 'Thing', name: 'Kinderwunschbehandlung Europa' },
  ],
};
---

<SiteLayout
  title={title}
  description={description}
  canonicalPath="/"
  keywords="Kinderwunsch, IVF, ICSI, Klinik Europa, Eizellspende, Samenspende, PID, Fertilität"
  jsonLd={jsonLd}
>
  <FertilityApp client:load />
</SiteLayout>
